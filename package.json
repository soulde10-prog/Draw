{
  "name": "draw-roofing-tool",
  "version": "2.0.0",
  "description": "Advanced 2D/3D Roofing & Architecture Drawing Tool with Zoho integration",
  "author": "SoulJBC (Michael Robert John Davidson De Meyer)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SoulJBC/Draw"
  },
  "type": "module",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "server": "node backend/server.js",
    "frontend": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "build:prod": "webpack --mode production && echo 'Frontend built to dist/'",
    "lint": "eslint . --ext .js",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "three": "^0.183.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.0",
    "eslint": "^9.0.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
